# 量化平台設定檔範本
# 複製此檔為 .env 並填入你的金鑰：cp config/.env.example config/.env

# ── FinMind API Token ─────────────────────────────────────────
# 免費申請：https://finmindtrade.com → 註冊後個人頁面取得
FINMIND_TOKEN=

# ── Telegram Bot ─────────────────────────────────────────────
# Bot Token：向 @BotFather 申請（/newbot）
TELEGRAM_BOT_TOKEN=
# Chat ID：向 @userinfobot 傳訊取得
TELEGRAM_CHAT_ID=

# ── FinLab API Token ──────────────────────────────────────────
# 免費版每日 500 MB 額度，VIP 5000 MB
# 申請：https://www.finlab.finance/payment
FINLAB_API_TOKEN=

# ── Anthropic API Key ─────────────────────────────────────────
# Telegram Bot Claude AI 查詢功能需要
# 申請：https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── API 寫入端點保護（選填，空字串表示不啟用）────────────────
API_KEY=

# ── Claude 模型設定 ───────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
BOT_CLAUDE_MODEL=claude-sonnet-4-6

# ── 訊號參數（可保留預設值）──────────────────────────────────
BREAKOUT_DAYS=20
MA_SHORT=5
MA_LONG=20
VOL_MULTIPLIER=1.5
